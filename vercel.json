{
  "regions": ["hnd1"],
  "functions": {
    "app/api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 30
    },
    "app/api/cron/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "app/api/pdca/*/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "app/api/automation/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "app/api/webhook/*/route.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "app/api/plaud-sync/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/plaud-sync",
      "schedule": "0 * * * *"
    }
  ]
}
